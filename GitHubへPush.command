#!/bin/zsh
# ============================================
# 読書ツール GitHubへのPush用スクリプト
# ============================================

# ツールのディレクトリに移動
cd "$(dirname "$0")"

echo "========================================"
echo " 🐙 GitHubへ進捗をアップロードします"
echo "========================================"

# 変更があればすべて追加してコミット
git add .
git commit -m "ユーザー指示による手動バックアップ: $(date +'%Y-%m-%d %H:%M:%S')"

# GitHubへプッシュ
echo "アップロード中..."
git push origin main

echo ""
echo "✅ 完了しました！"
